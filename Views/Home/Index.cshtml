@model List<KMITL_WebDev_MiniProject.Models.ActivityPreviewViewModel>
@using KMITL_WebDev_MiniProject.Entites

<link rel="stylesheet" href="~/css/Home/Index.css" asp-append-version="true"/>
<div class="activity-grid" id="activity-grid">
    @foreach(var activity in Model)
    {
            var ownerCount = activity.Act.OwnerId != Guid.Empty ? 1 : 0;
            var participantsCountIncludingOwner = activity.Act.Participants.Count + ownerCount;
            var mode = (RecruitingMode)activity.Act.RecruitingMode;
            var normalParticipantsCount = activity.Act.ActivityUsers.Count(au => au.Role == ActivityUserRole.Participant);
            var lockedParticipantsCount = activity.Act.ActivityUsers.Count(au => au.Role == ActivityUserRole.Locked);
            var guestSlots = Math.Max(0, activity.Act.MaxPeople - ownerCount);
            var publicSlots = Math.Max(0, guestSlots - lockedParticipantsCount);
            var isClosed = activity.Act.EventDate < DateTime.Now;
            var isFullForJoin = mode switch
            {
                RecruitingMode.RandomOnEventDay => false,
                RecruitingMode.OwnerSelect => normalParticipantsCount >= publicSlots,
                _ => participantsCountIncludingOwner >= activity.Act.MaxPeople
            };
        <div class="card">
                <div class="status-badge @(isClosed ? "closed" : (isFullForJoin ? "full" : "available"))">
                @if (isClosed)
                {
                    <span>Closed</span>
                }
                    else if (isFullForJoin)
                {
                    <span>Full</span>
                }
                else
                {
                    <span>Available</span>
                }
            </div>
            <div class="card-header">
                <div class="user-meta">Activity Owner: <strong>@activity.OwnerName</strong></div>
                <a href="@Url.Action("Detail","Activity", new { id = activity.Act.Id })" class="join-btn">
                    View
                </a>
            </div>
            @if(!string.IsNullOrEmpty(activity.Act.ImageUrl))
            {
                <div class="card-image">
                    <img src="@Url.Content("~/" + activity.Act.ImageUrl)" alt="@activity.Act.Name" >
                </div>
            }
            else
            {
                <div class="card-image" style="background-color: #f0f0f0; height: 200px; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                    <span style="color: #999;">No Image</span>
                </div>
            }
            <div class="card-body">
                <h3>@activity.Act.Name</h3>
                <p>@activity.Act.Description</p>
                <p><strong>Event Date:</strong> @activity.Act.EventDate.ToString("MMM dd, yyyy HH:mm")</p>
                <p><strong>Location:</strong> @activity.Act.Location</p>
                <p><strong>Participants:</strong> @participantsCountIncludingOwner / @activity.Act.MaxPeople</p>
                @if (activity.Act.Keywords != null && activity.Act.Keywords.Any())
                {
                    <p><strong>Keywords:</strong> @string.Join(", ", activity.Act.Keywords)</p>
                }
            </div>
        </div>
    }
</div>

@if(Model.Count == 0)
{
    <div style="text-align: center; padding: 40px;">
        <p>No activities available at the moment.</p>
    </div>
}