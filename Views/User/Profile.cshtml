@{
    ViewData["Title"] = "Home Page";
    TimeOnly v = new TimeOnly();
    int p = v.Second;
}

@model KMITL_WebDev_MiniProject.Models.ProfileViewModel

<div class="profile-container">

    <div class="profile-banner"></div>

    <div class="profile-avatar">
        <img src="@Url.Content($"~/{Model.ImagePath}")" asp-append-version="true" />
    </div>

    <div class="profile-info">
        <h2>@Model.RealUserName</h2>
        <div class="rating">@Model.Reputation ⭐</div>
    </div>

    <div class="profile-card">

        <div>First Name : @Model.FirstName</div>
        <div>Last Name : @Model.LastName</div>
        <div>Sex : @Model.Sex</div>

        <div class="profile-buttons">
            <a asp-controller="User" asp-action="ProfileEdit">Edit</a>

            <form asp-controller="Auth" asp-action="Logout" method="POST">
                <button type="submit">Logout</button>
            </form>
        </div>

    </div>

</div>

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        background: #f3f3f3;
    }

    /* Container */
    .profile-container {
        text-align: center;
    }

    /* Banner */
    .profile-banner {
        background: #ff9a8f;
        height: 180px;
        width: 100%;
    }

    /* Avatar */
    .profile-avatar {
        margin-top: -60px;
    }

    .profile-avatar img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid white;
    }

    /* Name + rating */
    .profile-info h2 {
        margin: 10px 0 0 0;
    }

    .rating {
        color: gold;
    }

    /* Main card */
    .profile-card {
        margin: 30px auto;
        width: 60%;
        background: #e6e6e6;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    /* Buttons */
    .profile-buttons {
        margin-top: 20px;
    }

    .profile-buttons a,
    .profile-buttons button {
        padding: 8px 16px;
        margin: 5px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
    }
</style>